#    Annotation properties
#################################################################

###  https://w3id.org/mod#createdWith
<https://w3id.org/mod#createdWith> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://example.org/digimon#hasAbility
:hasAbility rdf:type owl:ObjectProperty ;
            rdfs:domain :Digimon ;
            rdfs:range :Ability ;
            rdfs:label "has ability" .


###  http://example.org/digimon#hasAttack
:hasAttack rdf:type owl:ObjectProperty ;
           rdfs:domain :Digimon ;
           rdfs:range xsd:integer ;
           rdfs:label "has attack" .


###  http://example.org/digimon#hasDefense
:hasDefense rdf:type owl:ObjectProperty ;
            rdfs:domain :Digimon ;
            rdfs:range xsd:integer ;
            rdfs:label "has defense" .


###  http://example.org/digimon#hasDescription
:hasDescription rdf:type owl:ObjectProperty ;
                rdfs:domain :Move ;
                rdfs:range xsd:string ;
                rdfs:label "has description" .


###  http://example.org/digimon#hasElement
:hasElement rdf:type owl:ObjectProperty ;
            rdfs:domain :Digimon ;
            rdfs:range :Element ;
            rdfs:label "has element" .


###  http://example.org/digimon#hasEquipSlots
:hasEquipSlots rdf:type owl:ObjectProperty ;
               rdfs:domain :Digimon ;
               rdfs:range xsd:integer ;
               rdfs:label "has equip slots" .


###  http://example.org/digimon#hasHP
:hasHP rdf:type owl:ObjectProperty ;
       rdfs:domain :Digimon ;
       rdfs:range xsd:integer ;
       rdfs:label "has h p" .


###  http://example.org/digimon#hasInheritable
:hasInheritable rdf:type owl:ObjectProperty ;
                rdfs:domain :Move ;
                rdfs:range xsd:boolean ;
                rdfs:label "has inheritable" .


###  http://example.org/digimon#hasInteligence
:hasInteligence rdf:type owl:ObjectProperty ;
                rdfs:domain :Digimon ;
                rdfs:range xsd:integer ;
                rdfs:label "has inteligence" .


###  http://example.org/digimon#hasMoveElement
:hasMoveElement rdf:type owl:ObjectProperty ;
                rdfs:domain :Move ;
                rdfs:range :Element ;
                rdfs:label "has move element" .


###  http://example.org/digimon#hasPower
:hasPower rdf:type owl:ObjectProperty ;
          rdfs:domain :Move ;
          rdfs:range xsd:integer ;
          rdfs:label "has power" .


###  http://example.org/digimon#hasSP
:hasSP rdf:type owl:ObjectProperty ;
       rdfs:domain :Digimon ;
       rdfs:range xsd:integer ;
       rdfs:label "has s p" .


###  http://example.org/digimon#hasSPCost
:hasSPCost rdf:type owl:ObjectProperty ;
           rdfs:domain :Move ;
           rdfs:range xsd:integer ;
           rdfs:label "has s p cost" .


###  http://example.org/digimon#hasSkillDescription
:hasSkillDescription rdf:type owl:ObjectProperty ;
                     rdfs:domain :SupportSkill ;
                     rdfs:range xsd:string ;
                     rdfs:label "has skill description" .


###  http://example.org/digimon#hasSkillName
:hasSkillName rdf:type owl:ObjectProperty ;
              rdfs:domain :SupportSkill ;
              rdfs:range xsd:string ;
              rdfs:label "has skill name" .


###  http://example.org/digimon#hasSpeed
:hasSpeed rdf:type owl:ObjectProperty ;
          rdfs:domain :Digimon ;
          rdfs:range xsd:integer ;
          rdfs:label "has speed" .


###  http://example.org/digimon#hasStage
:hasStage rdf:type owl:ObjectProperty ;
          rdfs:domain :Digimon ;
          rdfs:range :EvolutionStage ;
          rdfs:label "has stage" .


###  http://example.org/digimon#hasSupportSkill
:hasSupportSkill rdf:type owl:ObjectProperty ;
                 rdfs:domain :Digimon ;
                 rdfs:range :SupportSkill ;
                 rdfs:label "has support skill" .


###  http://example.org/digimon#hasType
:hasType rdf:type owl:ObjectProperty ;
         rdfs:domain :Digimon ;
         rdfs:range :Type ;
         rdfs:label "has type" .


###  http://example.org/digimon#learnsMove
:learnsMove rdf:type owl:ObjectProperty ;
            rdfs:domain :Digimon ;
            rdfs:range :Move ;
            rdfs:label "learns move" .


###  http://example.org/digimon#strongAgainst
:strongAgainst rdf:type owl:ObjectProperty ;
               rdfs:label "strong against" .


#################################################################
#    Classes
#################################################################

###  http://example.org/digimon#Ability
:Ability rdf:type owl:Class ;
         rdfs:label "Ability" .


###  http://example.org/digimon#Digimon
:Digimon rdf:type owl:Class ;
         rdfs:subClassOf [ rdf:type owl:Restriction ;
                           owl:onProperty :learnsMove ;
                           owl:minCardinality "1"^^xsd:nonNegativeInteger
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :hasAbility ;
                           owl:cardinality "1"^^xsd:nonNegativeInteger
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :hasAttack ;
                           owl:cardinality "1"^^xsd:nonNegativeInteger
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :hasDefense ;
                           owl:cardinality "1"^^xsd:nonNegativeInteger
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :hasElement ;
                           owl:cardinality "1"^^xsd:nonNegativeInteger
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :hasEquipSlots ;
                           owl:cardinality "1"^^xsd:nonNegativeInteger
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :hasHP ;
                           owl:cardinality "1"^^xsd:nonNegativeInteger
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :hasInteligence ;
                           owl:cardinality "1"^^xsd:nonNegativeInteger
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :hasSP ;
                           owl:cardinality "1"^^xsd:nonNegativeInteger
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :hasSpeed ;
                           owl:cardinality "1"^^xsd:nonNegativeInteger
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :hasStage ;
                           owl:cardinality "1"^^xsd:nonNegativeInteger
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :hasSupportSkill ;
                           owl:cardinality "1"^^xsd:nonNegativeInteger
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :hasType ;
                           owl:cardinality "1"^^xsd:nonNegativeInteger
                         ] ;
         rdfs:label "Digimon" .


###  http://example.org/digimon#Element
:Element rdf:type owl:Class ;
         rdfs:label "Element" .


###  http://example.org/digimon#EvolutionStage
:EvolutionStage rdf:type owl:Class ;
                rdfs:label "Evolution Stage" .


###  http://example.org/digimon#MagicMove
:MagicMove rdf:type owl:Class ;
           rdfs:subClassOf :Move ;
           rdfs:label "Magic Move" .


###  http://example.org/digimon#Move
:Move rdf:type owl:Class ;
      rdfs:subClassOf [ rdf:type owl:Restriction ;
                        owl:onProperty :hasDescription ;
                        owl:cardinality "1"^^xsd:nonNegativeInteger
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :hasInheritable ;
                        owl:cardinality "1"^^xsd:nonNegativeInteger
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :hasMoveElement ;
                        owl:cardinality "1"^^xsd:nonNegativeInteger
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :hasSPCost ;
                        owl:cardinality "1"^^xsd:nonNegativeInteger
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :hasPower ;
                        owl:maxCardinality "1"^^xsd:nonNegativeInteger
                      ] ;
      rdfs:label "Move" .


###  http://example.org/digimon#PhysicalMove
:PhysicalMove rdf:type owl:Class ;
              rdfs:subClassOf :Move ;
              rdfs:label "Physical Move" .


###  http://example.org/digimon#SupportMove
:SupportMove rdf:type owl:Class ;
             rdfs:subClassOf :Move ;
             rdfs:label "Support Move" .


###  http://example.org/digimon#SupportSkill
:SupportSkill rdf:type owl:Class ;
              rdfs:subClassOf [ rdf:type owl:Restriction ;
                                owl:onProperty :hasSkillDescription ;
                                owl:cardinality "1"^^xsd:nonNegativeInteger
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :hasSkillName ;
                                owl:cardinality "1"^^xsd:nonNegativeInteger
                              ] ;
              rdfs:label "Support Skill" .


###  http://example.org/digimon#Type
:Type rdf:type owl:Class ;
      rdfs:label "Type" .

