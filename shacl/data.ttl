@prefix ns:   <http://example.org/digimon#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .


ns:Rookie a ns:EvolutionStage .
ns:Champion a ns:EvolutionStage .

ns:Fire a ns:Attribute .
ns:Light a ns:Attribute .
ns:Dark a ns:Attribute .
ns:Neutral a ns:Attribute .
ns:Water a ns:Attribute .
ns:Plant a ns:Attribute .
ns:Earth a ns:Attribute .


ns:Vaccine a ns:Type .
ns:Virus a ns:Type .
ns:Data a ns:Type .
ns:Free a ns:Type .

ns:Agumon a ns:Digimon ;
    ns:hasEvolutionStage ns:Rookie ;
    ns:hasType ns:Vaccine ;
    ns:hasAttribute ns:Fire ;
    ns:hp 1050 ;
    ns:spd 25
    ns:learnsMove ns:WolkenapalmI .

ns:WolkenapalmI a ns:Move ;
    ns:spCost 3;
    ns:hasMoveElement ns:Fire .

ns:ErrorMon_Type a ns:Digimon ;
    ns:hasEvolutionStage ns:Champion ;
    ns:hasType ns:MagicType ; # ERROR: No está en la lista sh:in de shapes.ttl
    ns:hasAttribute ns:Neutral ;
    ns:hp 500 .

ns:ErrorMon_NoStage a ns:Digimon ;
    ns:hasType ns:Data ;
    ns:hasAttribute ns:Water ;
    ns:hp 800 . # ERROR: Falta hasEvolutionStage (sh:minCount 1)

ns:ErrorMon_Stats a ns:Digimon ;
    ns:hasEvolutionStage ns:Rookie ;
    ns:hasType ns:Virus ;
    ns:hasAttribute ns:Dark ;
    ns:hp "Muy alto" ; # ERROR: Se esperaba xsd:integer
    ns:spd -10 .      # ERROR: Violación de sh:minInclusive 0

ns:ErrorMove_Nocost a ns:Move ;
        ns:hasMoveElement ns:Dark .

ns:ErrorSupport_NoDesc a ns:SupportMove .
