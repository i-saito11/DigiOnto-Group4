###  http://w3id.org/digiOntoG4hasElement
<http://w3id.org/digiOntoG4hasElement> rdf:type owl:ObjectProperty ;
                                       rdfs:domain <http://w3id.org/digiOntoG4Digimon> ;
                                       rdfs:range <http://w3id.org/digiOntoG4Element> ;
                                       rdfs:label "has element" ;
                                       <http://www.w3.org/2004/02/skos/core#definition> "Relaciona un Digimon con su elemento."@es ;
                                       <http://www.w3.org/2004/02/skos/core#prefLabel> "has element" .


