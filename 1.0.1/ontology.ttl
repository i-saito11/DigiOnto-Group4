                                            rdfs:range <http://w3id.org/digiOntoG4Element> ;
                                            rdfs:label "is strong against" ;
                                            <http://www.w3.org/2004/02/skos/core#definition> "Indica ventaja de un elemento frente a otro."@es ;
                                            <http://www.w3.org/2004/02/skos/core#prefLabel> "is strong against" .


###  http://w3id.org/digiOntoG4isStrongTypeAgainst
<http://w3id.org/digiOntoG4isStrongTypeAgainst> rdf:type owl:ObjectProperty ;
